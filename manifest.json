{
  "provides": "embedded",
  "linklib-dir": "linked-libs",
  "sources": [
    "src/api/**"
  ],
  "presets": {
    "arduino_uno": {
      "target": "elf-avr",
      "cpu": "atmega328p",
      "opt": "Oz",
      "linker": "builtin",
      "link-args": [
        "-T",
        "arduino.ld",
        "--gc-sections"
      ],
      "use-stdlib": false,
      "link-libc": false,
      "no-entry": true,
      "features": [
        "BOARD_ARDUINO_UNO",
        "MCU_ATMEGA328P",
        "BACKEND_AVR"
      ]
    },
    "esp32c3_devkit": {
      "target": "elf-riscv32",
      "cpu": "rvimac",
      "cpu-flags": "+m",
      "riscv-abi": "int-only",
      "memory-env": "none",
      "reloc": "none",
      "opt": "Oz",
      "linker": "builtin",
      "link-args": [
        "-T",
        "esp32c3.ld",
        "--gc-sections"
      ],
      "use-stdlib": false,
      "link-libc": false,
      "no-entry": true,
      "features": [
        "BOARD_ESP32C3_DEVKIT",
        "MCU_ESP32C3",
        "BACKEND_ESP32C3"
      ]
    }
  },
  "features": {
    "BOARD_ARDUINO_UNO": {
      "sources": [
        "src/boards/arduino_uno/**"
      ]
    },
    "MCU_ATMEGA328P": {
      "sources": [
        "src/boards/arduino_uno/**",
        "src/core/core.c3",
        "src/backends/avr/atmega328p/**"
      ]
    },
    "BOARD_ESP32C3_DEVKIT": {
      "sources": [
        "src/boards/esp32c3_devkit/**"
      ]
    },
    "MCU_ESP32C3": {
      "sources": [
        "src/boards/esp32c3_devkit/**",
        "src/core/core.c3",
        "src/backends/esp32/esp32c3/**"
      ]
    }
  },
  "targets": {
    "elf-avr": {
      "dependencies": [],
      "linked-libraries": []
    },
    "elf-riscv32": {
      "dependencies": [],
      "linked-libraries": []
    }
  }
}
